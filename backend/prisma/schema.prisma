// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
  moduleFormat    = "cjs"
}

//===== User ===== 
model User {
  id                 Int       @id @default(autoincrement())
  email              String    @unique
  password           String     
  userName           String?   @map("user_name")
  phoneHash          String?   @unique // hash от номера  
  phoneEnc           String?   // сам номер телефона, зашифрованный AES-ключом
  role               UserRole  @default(REGULAR)
  isVerified         Boolean   @default(false) @map("is_verified")
  ActivationLink     String?   @map("activation_link") 
  //isTwoFactorEnable  Boolean  @default(false) @map("is_two_factor_enabled")
  orders             Order[]
  tokens             Token[]
  
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

enum UserRole {
  REGULAR
  ADMIN
}


model Order {
  id                  Int @id  @default(autoincrement())
  price               BigInt
  time_order          DateTime @default(now())
  status              String
  checkout            String
  adress_destination  String

  userId              Int
  user               User     @relation(fields: [userId], references: [id])

  phone_customer      String

  @@map("orders")
}


model Token {
  id           Int      @id @default(autoincrement())
  refreshToken String   @unique
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@index([userId])
  @@map("tokens")
}